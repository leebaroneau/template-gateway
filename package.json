{
  "name": "@leebaroneau/template-gateway",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "description": "Brand-agnostic runtime MCP gateway: thin proxy to Composio Tool Router with per-profile entity routing via X-Composio-User-Id header. Also ships reference scaffolding (allowlists, scripts, docs) for new-brand onboarding.",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "list-tools": "node scripts/composio-list-tools.mjs",
    "create-servers": "node scripts/composio-create-servers.mjs"
  },
  "dependencies": {
    "@composio/core": "^0.10.0",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "minimist": "^1.2.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/node": "^24.0.0",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.0.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
