PORT=3000
API_BASE_URL=http://localhost:3000
ALLOWED_EMAIL_DOMAINS=example.com
ENABLED_PROVIDERS=microsoft,google,pipedrive
TOKEN_STORE_PATH=./data/tokens.json
AUDIT_LOG_PATH=./data/audit.jsonl
API_BEARER_TOKENS=

# Microsoft 365 (native OAuth via Microsoft Graph)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=
MICROSOFT_REDIRECT_URI=http://localhost:3000/auth/microsoft/callback
MICROSOFT_ALLOWED_TENANTS=
MICROSOFT_ALLOWED_DOMAINS=example.com
MICROSOFT_TOKEN_STORE_PATH=./data/microsoft-tokens.json
# Generate with: openssl rand -base64 32
MICROSOFT_TOKEN_STORE_KEY=
MICROSOFT_SCOPES=offline_access User.Read Mail.Read Calendars.Read

# Google Workspace (native OAuth via Google APIs) — implementation lands in a
# later plan (Google native); env vars listed here so wrapper repos can pre-stage.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
GOOGLE_ALLOWED_DOMAINS=example.com
GOOGLE_TOKEN_STORE_PATH=./data/google-tokens.json
# Generate with: openssl rand -base64 32
GOOGLE_TOKEN_STORE_KEY=
GOOGLE_SCOPES=openid email profile offline_access https://www.googleapis.com/auth/gmail.readonly https://www.googleapis.com/auth/gmail.send https://www.googleapis.com/auth/calendar.readonly

# Pipedrive CRM (native OAuth)
PIPEDRIVE_CLIENT_ID=
PIPEDRIVE_CLIENT_SECRET=
PIPEDRIVE_REDIRECT_URI=http://localhost:3000/auth/pipedrive/callback
# Fallback workspace subdomain (e.g. `acme` for acme.pipedrive.com). Only used
# when the OAuth token response omits `api_domain` — Pipedrive returns the
# authoritative per-user workspace URL there, which the provider always prefers.
PIPEDRIVE_COMPANY_DOMAIN=
PIPEDRIVE_ALLOWED_DOMAINS=example.com
PIPEDRIVE_TOKEN_STORE_PATH=./data/pipedrive-tokens.json
# Generate with: openssl rand -base64 32
PIPEDRIVE_TOKEN_STORE_KEY=
# Empty by default — Pipedrive apps use the scopes selected in the marketplace
# console. Override here if you need to force a specific space-delimited set.
PIPEDRIVE_SCOPES=
PIPEDRIVE_AUTHORIZE_URL=https://oauth.pipedrive.com/oauth/authorize
PIPEDRIVE_TOKEN_URL=https://oauth.pipedrive.com/oauth/token

# --- Composio (opt-in fallback) ---
# Enable Composio-backed providers by setting ENABLE_COMPOSIO_PROVIDERS=true
# and adding microsoft-composio and/or google-composio to ENABLED_PROVIDERS.
# Composio is no longer the default upstream for Microsoft/Google; see
# docs/superpowers/specs/2026-05-24-google-native-and-composio-demotion-design.md.
ENABLE_COMPOSIO_PROVIDERS=false
COMPOSIO_API_KEY=
COMPOSIO_BINDING_STORE_PATH=./data/composio-bindings.json
COMPOSIO_CLIENT_SLUG=local
COMPOSIO_MICROSOFT_TOOLKITS=outlook,calendar,onedrive
COMPOSIO_GOOGLE_TOOLKITS=gmail,googlecalendar,googledrive
COMPOSIO_AUTH_CONFIGS_JSON={}
