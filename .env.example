PORT=3000
API_BASE_URL=http://localhost:3000
ALLOWED_EMAIL_DOMAINS=example.com
ENABLED_PROVIDERS=microsoft,pipedrive
TOKEN_STORE_PATH=./data/tokens.json
AUDIT_LOG_PATH=./data/audit.jsonl
API_BEARER_TOKENS=

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=
MICROSOFT_REDIRECT_URI=http://localhost:3000/auth/microsoft/callback
MICROSOFT_ALLOWED_TENANTS=
MICROSOFT_ALLOWED_DOMAINS=example.com
MICROSOFT_TOKEN_STORE_PATH=./data/microsoft-tokens.json
# Generate with: openssl rand -base64 32
MICROSOFT_TOKEN_STORE_KEY=
MICROSOFT_SCOPES=offline_access User.Read Mail.Read Calendars.Read

PIPEDRIVE_CLIENT_ID=
PIPEDRIVE_CLIENT_SECRET=
PIPEDRIVE_REDIRECT_URI=http://localhost:3000/auth/pipedrive/callback
# Fallback workspace subdomain (e.g. `acme` for acme.pipedrive.com). Only used
# when the OAuth token response omits `api_domain` — Pipedrive returns the
# authoritative per-user workspace URL there, which the provider always prefers.
PIPEDRIVE_COMPANY_DOMAIN=
PIPEDRIVE_ALLOWED_DOMAINS=example.com
PIPEDRIVE_TOKEN_STORE_PATH=./data/pipedrive-tokens.json
# Generate with: openssl rand -base64 32
PIPEDRIVE_TOKEN_STORE_KEY=
# Empty by default — Pipedrive apps use the scopes selected in the marketplace
# console. Override here if you need to force a specific space-delimited set.
PIPEDRIVE_SCOPES=
PIPEDRIVE_AUTHORIZE_URL=https://oauth.pipedrive.com/oauth/authorize
PIPEDRIVE_TOKEN_URL=https://oauth.pipedrive.com/oauth/token
